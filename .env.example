# ============================================================
# EduVault Backend – Environment Variables
# Copy this file to .env and fill in your real values
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=production
# Set this to your Netlify or custom frontend URL so CORS works.
# Example: https://eduvault.netlify.app
FRONTEND_URL=https://YOUR_NETLIFY_URL.netlify.app

# --- JWT Secret (generate a random string, keep it secret!) ---
JWT_SECRET=change_this_to_a_very_long_random_secret_string

# --- Admin Credentials ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Google Drive / Sheets Integration ---
# Option A (RECOMMENDED for Railway / cloud hosting):
#   Paste the ENTIRE contents of your google-service-account.json as a single-line string.
#   Easiest way: cat google-service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B (local development only): path to key file on disk
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./google-service-account.json

# --- Google Sheets IDs ---
SHEETS_ID=1OnbaIhAEjqjfUA0xEcfJDfCoR5Iot3vhjr5w0F5fsRM
SHEETS_TAB_GRADES=Grades
SHEETS_TAB_USERS=Users
SHEETS_TAB_SUBJECTS=Subjects

# --- Google Drive ---
DRIVE_MAIN_FOLDER_ID=10X8N1JB6V99f1zMJibT_407gZcQGdgHY
DRIVE_HIGH_ACHIEVERS_FOLDER_ID=1Q8mE7R75nE9jTaAbjvhUi4Wgq8TI_Evl

# --- App Settings ---
HIGH_SCORE_THRESHOLD=80
MAX_FILE_SIZE_MB=10
